@model Presentation.ViewModels.Account.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<section class="page-segment page-segment-light">
    <div class="segment-inner">
        <p class="eyebrow">Account</p>
        <h1>Reset Password</h1>

        <form class="admin-form"
              asp-controller="Account"
              asp-action="ResetPassword"
              method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="validation-summary"></div>
            }

            <input asp-for="UserId" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" />
                <span asp-validation-for="ConfirmPassword" class="validation-message"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="button-primary">
                    Reset Password
                </button>

                <a asp-controller="Account"
                   asp-action="Login"
                   class="button-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>