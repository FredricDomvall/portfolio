@model Presentation.ViewModels.Account.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<section class="page-segment page-segment-light">
    <div class="segment-inner">
        <p class="eyebrow">Account</p>
        <h1>Forgot Password</h1>

        <form class="admin-form"
              asp-controller="Account"
              asp-action="ForgotPassword"
              method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="validation-summary"></div>
            }

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="validation-message"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="button-primary">
                    Send Reset Link
                </button>

                <a asp-controller="Account"
                   asp-action="Login"
                   class="button-secondary">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>