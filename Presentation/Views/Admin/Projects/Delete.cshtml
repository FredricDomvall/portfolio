@model Domain.Entities.PortfolioProject

@{
    ViewData["Title"] = "Delete Project";
}

<section class="page-segment page-segment-light">
    <div class="segment-inner">
        <p class="eyebrow">Administration</p>
        <h1>Delete Project</h1>

        <article class="depth-card">
            <h2>@Model.Title</h2>
            <p>@Model.Description</p>

            <p>Are you sure you want to delete this project?</p>

            <form class="admin-form"
                  asp-controller="AdminProjects"
                  asp-action="DeleteConfirmed"
                  asp-route-id="@Model.Id"
                  method="post">
                @Html.AntiForgeryToken()

                <div class="form-actions">
                    <button type="submit" class="button-primary">Delete Project</button>

                    <a asp-controller="AdminProjects"
                       asp-action="Index"
                       class="button-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </article>
    </div>
</section>